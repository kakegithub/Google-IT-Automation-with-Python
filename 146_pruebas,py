#!/usr/bin/env python3

# Función para validar un nombre de usuario.
# Verifica que sea una cadena, tenga al menos 'minlen' caracteres y sea alfanumérico.
def validate_user(username, minlen):
  # Aseguramos que username sea una cadena de texto
  assert type(username) == str, "username must be a string"
  # Si minlen es menor que 1, lanzamos un error
  if minlen < 1:
    raise ValueError("minlen must be at least 1")

  # Si la longitud es menor que minlen, no es válido
  if len(username) < minlen:
    return False
  # Si no es alfanumérico, no es válido
  if not username.isalnum():
    return False
  # Si pasa todo, es válido
  return True


